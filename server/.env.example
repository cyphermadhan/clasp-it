# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=*

# ─── Storage ──────────────────────────────────────────────────────────────────
# Leave unset to use in-memory storage (local dev only)
DATABASE_URL=postgresql://user:password@localhost:5432/clasp_it
REDIS_URL=redis://localhost:6379

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Leave unset to print magic links to console instead of sending email
RESEND_API_KEY=re_...
RESEND_FROM=noreply@clasp-it.com

# ─── Dodo Payments ────────────────────────────────────────────────────────────
DODO_API_KEY=sk_test_...
DODO_WEBHOOK_KEY=whsec_...
DODO_PRODUCT_PRO_MONTHLY=prd_...     # $8/month
DODO_PRODUCT_PRO_ANNUAL=prd_...      # $72/year
DODO_ENV=live_mode                   # test_mode | live_mode

# ─── App ──────────────────────────────────────────────────────────────────────
# Used for magic link redirects and return URLs
APP_URL=http://localhost:5500
