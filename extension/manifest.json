{
  "manifest_version": 3,
  "name": "Clasp-it for Claude Code",
  "version": "1.0.0",
  "description": "Pick any webpage element and send it to Claude Code",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "webNavigation",
    "webRequest",
    "sidePanel"
  ],

  "optional_permissions": [],

  "host_permissions": [
    "https://claspit.dev/*",
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "action": {
    "default_title": "Clasp-it for Claude Code",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "web_accessible_resources": [
    {
      "resources": ["panel.html", "sidepanel.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
